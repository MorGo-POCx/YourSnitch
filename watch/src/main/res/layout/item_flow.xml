<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:minHeight="58dp"
    android:background="@drawable/glass_card_sm"
    android:paddingHorizontal="14dp"
    android:paddingVertical="11dp">

    <TextView
        android:id="@+id/flowFlag"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="12dp"
        android:text="🌐"
        android:textSize="24sp" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/flowDomain"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="@font/space_grotesk"
            android:textStyle="bold"
            android:text="example.com"
            android:textColor="@color/ys_text"
            android:textSize="15sp"
            android:maxLines="1"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/flowSub"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:fontFamily="@font/ibm_plex_mono_medium"
            android:text="→ Ireland · 3 sec ago"
            android:textColor="@color/ys_accent2"
            android:textSize="11.5sp" />
    </LinearLayout>

    <View
        android:id="@+id/flowDot"
        android:layout_width="8dp"
        android:layout_height="8dp"
        android:background="@drawable/dot"
        android:backgroundTint="@color/ys_accent"
        android:visibility="gone" />
</LinearLayout>
